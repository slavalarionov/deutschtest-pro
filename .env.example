# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
# Optional Cloudflare Worker proxy. Set both vars to route through the proxy;
# leave them empty for direct API access from a non-Timeweb environment.
ELEVENLABS_API_URL_OVERRIDE=
ELEVENLABS_PROXY_SECRET=

# OpenAI
OPENAI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=https://deutschtest.pro

# Resend (registration password email — sole signup email; no Supabase “confirm signup”)
RESEND_API_KEY=
# Required for real users: verify your domain in Resend, then set e.g.:
# EMAIL_FROM=DeutschTest.pro <noreply@yourdomain.com>
# onboarding@resend.dev only allows sending to your Resend-account email in many cases.

# ============================================================================
# Tochka acquiring (RU). The flat /acquiring/v1.0/payments contract — see
# lib/tochka/client.ts. MERCHANT_ID is intentionally NOT used: the v1.0
# Create Payment Operation request only takes customerCode.
# ============================================================================

# Long-lived JWT token issued in the Tochka cabinet for acquiring scope.
TOCHKA_JWT_TOKEN=

# 9+ digit customerCode that owns the merchant account; obtained via
# `GET /open-banking/v1.0/customers` with the JWT above. See scripts/check-tochka-customers.ts.
TOCHKA_CUSTOMER_CODE=

# merchantId (siteUid) — идентификатор торговой точки в интернет-эквайринге.
# Get it from the Tochka cabinet support chat:
#   "Нужен merchantId (siteUid) для интеграции интернет-эквайринга
#    с внешним сервисом, customerCode: <YOUR_CUSTOMER_CODE>"
# Без него Create Payment Operation падает с 400 "Field merchantId is required".
TOCHKA_MERCHANT_ID=

# RS256 public key used to verify acquiringInternetPayment webhooks.
# Accepts either PEM ("-----BEGIN PUBLIC KEY-----…") or JWK JSON
# ('{"kty":"RSA","n":"…","e":"AQAB"}'). Leave EMPTY until the key is
# published by Tochka — the integration will run on the polling fallback
# in /api/payments/[orderId]/status until then.
TOCHKA_WEBHOOK_PUBLIC_KEY=

# Defaults to https://enter.tochka.com/uapi/. Override only for staging.
TOCHKA_API_BASE_URL=https://enter.tochka.com/uapi/
