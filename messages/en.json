    "pricing": {
      "eyebrow": "03 — PRICING",
      "title": "Simple pricing",
      "subtitle": "Pick a module pack and spend your balance on any of the four types: Lesen, Hören, Schreiben, Sprechen."
    },
    "faq": {
      "eyebrow": "04 — ANSWERS",
      "titleStrong": "Common questions.",
      "titleMuted": "Clear answers.",
      "items": {
        "realism": {
          "q": "How close is the simulator to the real Goethe exam?",
          "a": "The format matches one-to-one: the same sections, the same number of tasks, the same time limits, the same assessment criteria as the official Goethe standard. The difference is that every test is uniquely generated by AI. You cannot memorise answers — every session is fresh preparation."
        },
        "aiScoring": {
          "q": "How does the AI grade writing and speaking?",
          "a": "By the official Goethe criteria: task completion, coherence, vocabulary, grammar — plus fluency and pronunciation for speaking. You get a 0-100 score, a pass/fail verdict, and a detailed breakdown of strengths and weaknesses with concrete recommendations."
        },
        "officialExam": {
          "q": "Is your certificate officially recognised?",
          "a": "No. DeutschTest.pro is a preparation tool, not an accredited examination centre. The actual certificate can only be issued by the Goethe-Institut or its in-person partners. We prepare you so that you pass there on your first attempt."
        },
        "modulesPricing": {
          "q": "What is a module and how do packages work?",
          "a": "A module is one part of the exam: Lesen, Hören, Schreiben, or Sprechen. You choose what to practise — for example, three Sprechen sessions in a row if that is your weakest area. You get 3 free modules on signup. After that, you buy packages of 10, 20, or 40 modules. No subscription, no auto-renewal."
        },
        "microphone": {
          "q": "What do I need technically to practise?",
          "a": "For Lesen, Hören, and Schreiben — any browser on desktop, laptop, tablet, or phone. For Sprechen you also need a microphone: a laptop mic, a headset, or your phone's built-in mic all work fine. Nothing to install, configure, or download."
        },
        "refund": {
          "q": "Can I get a refund on a package?",
          "a": "Yes. If you have bought a package but not yet used any paid modules, we refund the full amount within 14 days. The 3 free modules on signup do not count as usage. Simply email our support team."
        }
      }
    }
  },
